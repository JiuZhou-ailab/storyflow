# Storyflow local environment example
#
# This file is for local development only. Copy values into .env, put personal
# overrides in .env.local, and put dev-runtime defaults in .env.dev. GitHub
# release builds use repository vars/secrets, and deployed brokers use their
# own server-side environment.

# ---------------------------------------------------------------------------
# Local agent / CLI development
# ---------------------------------------------------------------------------

# Optional local model credentials for CLI and development runs.
ANTHROPIC_API_KEY=sk-ant-...

# Optional hosted MCP endpoint for development.
CRAFT_MCP_URL=http://localhost:3000/v1/links/YOUR_SECRET_LINK_ID/mcp
CRAFT_MCP_TOKEN=your-bearer-token-here

# ---------------------------------------------------------------------------
# Desktop client auth values that are safe to bake into a packaged app
# ---------------------------------------------------------------------------

CRAFT_CLIENT_AUTH_REQUIRED=true

# Production desktop builds must use a deployed HTTPS broker.
# Local electron:dev may use http://localhost:9100 when scripts/auth-broker-dev.ts is running.
CRAFT_CLIENT_AUTH_BROKER_URL=https://storyflow-auth.zjding.com

# Public desktop Feishu app id. The Feishu app secret must stay on the broker.
CRAFT_CLIENT_FEISHU_APP_ID=cli_xxx
CRAFT_CLIENT_FEISHU_CALLBACK_PORT=6477
CRAFT_CLIENT_FEISHU_LOGIN_TIMEOUT_MS=90000

# Public Neon Auth client settings for desktop login.
CRAFT_CLIENT_NEON_AUTH_BASE_URL=https://your-neon-auth.example.com/neondb/auth
CRAFT_CLIENT_NEON_AUTH_USERNAME_EMAIL_DOMAIN=users.craft.invalid
CRAFT_CLIENT_NEON_AUTH_ORIGIN=http://localhost:9100

# Secret used by official packaged builds to seed the managed model gateway.
# Keep this in GitHub Actions secrets for release builds.
CRAFT_CLIENT_GATEWAY_TOKEN=

# ---------------------------------------------------------------------------
# Auth broker / Web UI server-only values
# ---------------------------------------------------------------------------

# These values belong on the broker/server. Do not bake them into Electron.
CRAFT_WEBUI_FEISHU_APP_ID=cli_xxx
CRAFT_WEBUI_FEISHU_APP_SECRET=feishu-secret
CRAFT_WEBUI_FEISHU_REDIRECT_URI=http://localhost:9100/api/client-auth/feishu/callback
CRAFT_WEBUI_FEISHU_SCOPE=contact:user.id:readonly
CRAFT_WEBUI_FEISHU_ALLOW_ALL_USERS=false
CRAFT_WEBUI_FEISHU_INTERNAL_TENANT_KEYS=

CRAFT_WEBUI_NEON_AUTH_BASE_URL=https://your-neon-auth.example.com/neondb/auth
CRAFT_WEBUI_NEON_AUTH_USERNAME_EMAIL_DOMAIN=users.craft.invalid
CRAFT_WEBUI_PASSWORD_AUTH_ENABLED=false

# ---------------------------------------------------------------------------
# Optional integrations
# ---------------------------------------------------------------------------

GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

SLACK_OAUTH_CLIENT_ID=your-slack-client-id
SLACK_OAUTH_CLIENT_SECRET=your-slack-client-secret

MICROSOFT_OAUTH_CLIENT_ID=your-microsoft-client-id

# Sentry ingest URL is public, but still keep production values in CI config.
SENTRY_ELECTRON_INGEST_URL=https://your-public-key@o0.ingest.sentry.io/0

# ---------------------------------------------------------------------------
# Legacy / advanced gateway values
# ---------------------------------------------------------------------------

# Legacy Worker model gateway config. Not used by the simplified desktop default path.
# STORYFLOW_GATEWAY_JWT_SECRET=
# CLOUDFLARE_AI_GATEWAY_TOKEN=cfut_xxx
# WANGSU_UPSTREAM_BASE_URL=https://gateway.ai.cloudflare.com/v1/<account>/<gateway>/custom-wangsu
